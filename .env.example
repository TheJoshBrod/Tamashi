# Copy this to .env and fill in your values.

# --- OpenAI (or any LiteLLM-supported provider) ---
OPENAI_API_KEY=sk-...

# --- Anthropic (if using claude/* models) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Twilio ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...

# --- App settings ---
# Set to True during local ngrok testing to skip Twilio signature validation.
DEBUG=True

# Path to the SQLite database file (default: project root sessions.db)
# DB_PATH=sessions.db
