.installed.cfg
*.egg
MANIFEST

# Virtual environments
env/
venv/
venv3/
.venv/
ENV/
env.bak/
venv.bak/

# Dependency manager artifacts (lock files are per-project — commit in apps, ignore in libraries)
# Uncomment any you want to ignore globally:
# Pipfile.lock
# uv.lock
# poetry.lock
# pdm.lock
# pixi.lock
.python-version
poetry.toml
pdm.toml
.pdm-python
.pdm-build/
.pixi/

