########################
# gitignore Template
# Generic — works across all projects
########################

########################
# Secrets / Environment
########################

# Environment files
.env
.env.*
.env.local
.env.*.local
!.env.example

# Secret files
secrets/
.envrc
.direnv/

# Credentials & keys
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
credentials.json
.pypirc

########################
# Logs & Temp
########################

*.log
*.log.*
logs/
tmp/
output/
*.tmp
*.bak
*.orig
*.rej

########################
# OS-specific
########################

# macOS
.DS_Store
._*
.AppleDouble
.LSOverride
Icon
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*Zone.Identifier

# Linux
.fuse_hidden*
.nfs*
.Trash-*

# Google Drive / Dropbox
.dropbox*

